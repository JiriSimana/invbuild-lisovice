---
// Kontakt — sjednocený formulář bez dělení, čistá vertikální linka
export interface Props {
  phone?: string;
  altPhone?: string;
  email?: string;
  website?: string;
}
const {
  phone    = '+420 704 971 814',
  altPhone = '+420 704 971 809',
  email    = 'info@invbuild.cz',
  website  = 'www.invbuild.cz',
} = Astro.props;
---

<div class="kontakt">
  <div class="kontakt__intro" data-reveal>
    <p class="kontakt__lead">
      V rámci probíhající rekonstrukce má nový majitel velkou výhodu si říct,
      jaké úpravy či změny se dají realizovat dle vlastních přání.
    </p>
    <div class="kontakt__direct">
      <a href={`tel:${altPhone.replace(/\s/g, '')}`}>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        {altPhone}
      </a>
      <a href={`mailto:${email}`}>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M4 4h16a2 2 0 012 2v12a2 2 0 01-2 2H4a2 2 0 01-2-2V6a2 2 0 012-2z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M22 6l-10 7L2 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        {email}
      </a>
    </div>
  </div>

  <form class="form" id="poptavka" method="POST" action="/api/poptavka" novalidate data-reveal>
    <div class="form__field">
      <label for="name">Jméno a příjmení</label>
      <input id="name" name="name" type="text" required autocomplete="name" />
    </div>

    <div class="form__field">
      <label for="phone">Telefon</label>
      <input id="phone" name="phone" type="tel" required autocomplete="tel" />
    </div>

    <div class="form__field">
      <label for="email">E-mail</label>
      <input id="email" name="email" type="email" required autocomplete="email" />
    </div>

    <div class="form__field">
      <label for="message">Vaše zpráva</label>
      <textarea id="message" name="message" rows="4" required placeholder="Co byste rádi věděli o projektu?"></textarea>
    </div>

    <label class="form__gdpr">
      <input type="checkbox" name="gdpr" required />
      <span>Souhlasím se <a href="/gdpr">zpracováním osobních údajů</a>.</span>
    </label>

    <button type="submit" class="form__submit">
      <span>Odeslat poptávku</span>
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <path d="M3 11L11 3M11 3H5M11 3V9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </form>
</div>

<style>
  .kontakt {
    max-width: 620px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: clamp(2rem, 4vw, 3rem);
  }

  .kontakt__intro { text-align: center; }
  .kontakt__lead {
    font-size: var(--fs-base);
    line-height: var(--lh-snug);
    color: var(--muted);
    max-width: 50ch;
    margin-inline: auto;
  }
  .kontakt__direct {
    margin-top: 1.5rem;
    display: flex;
    justify-content: center;
    gap: clamp(1rem, 2vw, 2rem);
    flex-wrap: wrap;
  }
  .kontakt__direct a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--fs-sm);
    font-weight: 500;
    color: var(--ink);
    padding: 0.5rem 0;
    border-bottom: 1px solid transparent;
    transition: border-color var(--dur-fast) var(--ease-out),
                color var(--dur-fast) var(--ease-out);
  }
  .kontakt__direct a:hover {
    color: var(--accent-hover);
    border-bottom-color: var(--accent);
  }

  /* form */
  .form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .form__field { display: flex; flex-direction: column; gap: 0.4rem; }
  .form__field label {
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-extra);
    color: var(--muted);
    font-weight: 500;
  }
  .form__field input,
  .form__field textarea {
    background: transparent;
    border: 0;
    border-bottom: 1px solid var(--line);
    padding: 0.75rem 0;
    font-size: var(--fs-base);
    color: inherit;
    transition: border-color var(--dur-fast) var(--ease-out);
  }
  .form__field input:focus,
  .form__field textarea:focus {
    outline: none;
    border-bottom-color: var(--ink);
  }
  .form__field textarea {
    resize: vertical;
    min-height: 100px;
  }

  .form__gdpr {
    display: flex;
    gap: 0.55rem;
    align-items: flex-start;
    font-size: var(--fs-sm);
    color: var(--muted);
    line-height: 1.45;
  }
  .form__gdpr a {
    color: var(--ink);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--accent);
  }

  .form__submit {
    align-self: stretch;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1.05rem 1.75rem;
    background: var(--ink);
    color: var(--paper);
    border-radius: var(--radius-pill);
    font-size: var(--fs-sm);
    font-weight: 500;
    letter-spacing: 0.02em;
    margin-top: 0.5rem;
    transition: background var(--dur-fast) var(--ease-out),
                transform var(--dur-fast) var(--ease-out);
  }
  .form__submit:hover {
    background: var(--accent);
    color: var(--accent-ink);
    transform: translateY(-1px);
  }
  .form__submit svg {
    transition: transform var(--dur-fast) var(--ease-out);
  }
  .form__submit:hover svg { transform: translate(2px, -2px); }
</style>
