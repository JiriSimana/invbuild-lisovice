---
// Services — gateway karty na hlavní web INVBUILD.cz
// Každá karta = klikatelný odkaz na konkrétní sekci invbuild.cz
export interface Props {
  items: {
    title: string;
    blurb?: string;
    image: { src: string; alt: string };
    href: string;
    external?: boolean;
  }[];
}
const { items } = Astro.props;
---

<div class="services">
  {items.map((it, i) => (
    <a
      class="service"
      href={it.href}
      target={it.external ? '_blank' : undefined}
      rel={it.external ? 'noopener' : undefined}
      data-reveal
      style={`--reveal-delay: ${i * 100}ms`}
    >
      <figure class="service__media">
        <img src={it.image.src} alt={it.image.alt} loading="lazy" />
        <span class="service__hover-arrow" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 14 14" fill="none">
            <path d="M3 11L11 3M11 3H5M11 3V9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </figure>
      <header class="service__head">
        <span class="service__num lining">{String(i + 1).padStart(2, '0')}</span>
        <div class="service__text">
          <h4 class="service__title">{it.title}</h4>
          {it.blurb && <p class="service__blurb">{it.blurb}</p>}
        </div>
      </header>
    </a>
  ))}
</div>

<style>
  .services {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1.25rem, 2.5vw, 2rem);
  }
  @media (max-width: 880px) { .services { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 540px) { .services { grid-template-columns: 1fr; } }

  .service {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    text-decoration: none;
    color: inherit;
    transition: transform var(--dur-base) var(--ease-out);
  }
  .service:hover { transform: translateY(-3px); }

  .service__media {
    aspect-ratio: 4 / 5;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--paper-bone);
    position: relative;
  }
  .service__media img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 1s var(--ease-out);
  }
  .service:hover .service__media img { transform: scale(1.04); }

  /* hover arrow chip */
  .service__hover-arrow {
    position: absolute;
    top: 0.85rem; right: 0.85rem;
    width: 38px; height: 38px;
    display: grid; place-items: center;
    background: var(--paper);
    color: var(--ink);
    border-radius: 50%;
    opacity: 0;
    transform: translate(6px, -6px) scale(0.8);
    transition: opacity var(--dur-fast) var(--ease-out),
                transform var(--dur-base) var(--ease-out),
                background var(--dur-fast) var(--ease-out);
  }
  .service:hover .service__hover-arrow {
    opacity: 1;
    transform: translate(0, 0) scale(1);
    background: var(--accent);
    color: var(--accent-ink);
  }

  .service__head {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.8rem;
    align-items: baseline;
  }
  .service__num {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-wide);
    color: var(--accent);
  }
  .service__text {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .service__title {
    margin: 0;
    font-size: var(--fs-lg);
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
  }
  .service__blurb {
    font-size: var(--fs-sm);
    color: var(--muted);
    line-height: 1.45;
    margin: 0;
  }

  /* Dark section variant */
  :global(.section--dark) .service__title { color: var(--paper); }
  :global(.section--dark) .service__blurb { color: rgba(255,255,255,0.65); }
</style>
