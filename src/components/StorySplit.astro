---
// StorySplit — asymetrický 2-sloupec: text + foto. Žádný dropcap.
export interface Props {
  num?: string;
  eyebrow?: string;
  title: string;
  image: { src: string; alt: string };
  caption?: string;
  reverse?: boolean;
  variant?: 'light' | 'dark';
}
const {
  num, eyebrow, title, image, caption,
  reverse = false, variant = 'light',
} = Astro.props;
---

<div class:list={['split', reverse && 'split--reverse', `split--${variant}`]} data-reveal>
  <div class="split__text">
    {(num || eyebrow) && (
      <span class="eyebrow">
        {num && <span class="eyebrow__num">{num}</span>}
        {eyebrow && <span>{eyebrow}</span>}
      </span>
    )}
    <h2 class="split__title">{title}</h2>
    <div class="split__body"><slot /></div>
  </div>

  <figure class="split__media">
    <img src={image.src} alt={image.alt} loading="lazy" />
    {caption && <figcaption class="split__caption">{caption}</figcaption>}
  </figure>
</div>

<style>
  .split {
    display: grid;
    grid-template-columns: 1fr 1.15fr;
    gap: clamp(1.5rem, 4vw, 4rem);
    align-items: center;
  }
  .split--reverse { grid-template-columns: 1.15fr 1fr; }
  .split--reverse .split__text  { order: 2; }
  .split--reverse .split__media { order: 1; }

  @media (max-width: 920px) {
    .split,
    .split--reverse { grid-template-columns: 1fr; }
    .split--reverse .split__text  { order: 1; }
    .split--reverse .split__media { order: 2; }
  }

  .split__text {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 52ch;
  }
  .split__title {
    margin: 0;
    text-wrap: balance;
  }
  .split__body {
    font-size: var(--fs-base);
    line-height: var(--lh-base);
    color: var(--muted);
    margin-top: 0.25rem;
  }
  .split--dark .split__body  { color: rgba(255,255,255,0.78); }
  .split--dark .split__title { color: var(--paper); }
  .split--dark .eyebrow      { color: rgba(255,255,255,0.7); }
  .split--dark .eyebrow__num { color: var(--accent); }

  .split__body :global(p + p) { margin-top: 0.85rem; }
  .split__body :global(strong) {
    color: var(--ink);
    font-weight: 600;
  }
  .split--dark .split__body :global(strong) { color: var(--paper); }

  /* media */
  .split__media {
    border-radius: var(--radius-md);
    overflow: hidden;
    aspect-ratio: 4 / 3;
    background: var(--paper-bone);
    position: relative;
  }
  @media (max-width: 600px) {
    .split__media { aspect-ratio: 4 / 3; }
    .split { gap: 1.25rem; }
  }
  .split__media img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 1.2s var(--ease-out);
  }
  .split:hover .split__media img { transform: scale(1.03); }
  .split__caption {
    position: absolute;
    bottom: 0.75rem; left: 0.85rem; right: 0.85rem;
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: rgba(255,255,255,0.85);
    text-shadow: 0 1px 6px rgba(0,0,0,0.5);
    pointer-events: none;
  }
</style>
