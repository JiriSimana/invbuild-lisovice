---
// Gallery — large primary image, refined thumbnail strip, lighter chrome, magazine caption
export interface Props {
  images: { src: string; alt: string }[];
}
const { images } = Astro.props;
---

<div class="gallery" data-gallery>
  <div class="gallery__stage">
    {images.map((img, i) => (
      <figure class="gallery__main" data-active={i === 0 ? 'true' : 'false'} data-idx={i}>
        <img src={img.src} alt={img.alt} loading={i === 0 ? 'eager' : 'lazy'} />
      </figure>
    ))}

    <button class="gallery__arrow gallery__arrow--prev" aria-label="Předchozí" data-gal-prev>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
    <button class="gallery__arrow gallery__arrow--next" aria-label="Další" data-gal-next>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M9 6L15 12L9 18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>

  <div class="gallery__meta">
    <span class="gallery__caption" data-gal-caption>{images[0].alt}</span>
    <span class="gallery__counter">
      <span data-gal-current>01</span>
      <span class="gallery__counter-sep">/</span>
      <span>{String(images.length).padStart(2, '0')}</span>
    </span>
  </div>

  <div class="gallery__thumbs" role="list">
    {images.map((img, i) => (
      <button class="gallery__thumb"
              data-active={i === 0 ? 'true' : 'false'}
              data-go={i}
              aria-label={`Zobrazit foto ${i + 1}`}
              role="listitem">
        <img src={img.src} alt="" loading="lazy" />
      </button>
    ))}
  </div>
</div>

<style>
  .gallery {
    display: grid;
    gap: clamp(1rem, 2vw, 1.5rem);
  }

  .gallery__stage {
    position: relative;
    aspect-ratio: 16 / 10;
    background: var(--ink-soft);
    border-radius: var(--radius-md);
    overflow: hidden;
  }
  @media (max-width: 600px) {
    .gallery__stage { aspect-ratio: 4 / 3; border-radius: var(--radius-sm); }
  }
  .gallery__main {
    position: absolute; inset: 0;
    opacity: 0;
    transition: opacity 450ms var(--ease-out);
  }
  .gallery__main[data-active='true'] { opacity: 1; }
  .gallery__main img { width: 100%; height: 100%; object-fit: cover; }

  .gallery__arrow {
    position: absolute;
    top: 50%; transform: translateY(-50%);
    width: 44px; height: 44px;
    border-radius: 50%;
    background: rgba(250,250,247,0.92);
    color: var(--ink);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    display: grid; place-items: center;
    z-index: 2;
    transition: transform var(--dur-fast) var(--ease-out),
                background var(--dur-fast) var(--ease-out);
    opacity: 0;
  }
  .gallery__stage:hover .gallery__arrow,
  .gallery__arrow:focus-visible { opacity: 1; }
  .gallery__arrow:hover { background: var(--paper); transform: translateY(-50%) scale(1.05); }
  .gallery__arrow--prev { left: clamp(0.6rem, 1.5vw, 1.25rem); }
  .gallery__arrow--next { right: clamp(0.6rem, 1.5vw, 1.25rem); }
  /* na touch zařízeních šipky vždy viditelné */
  @media (hover: none) {
    .gallery__arrow { opacity: 1; width: 38px; height: 38px; }
  }

  /* meta row — caption + counter */
  .gallery__meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding-top: 0.5rem;
  }
  .gallery__caption {
    font-family: var(--font-sans);
    font-size: var(--fs-sm);
    color: var(--muted);
    font-style: italic;
  }
  .gallery__counter {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-wide);
    color: var(--muted-soft);
    display: flex; gap: 0.35rem;
  }
  .gallery__counter-sep { opacity: 0.5; }

  /* dark section: invert caption colors */
  :global(.section--dark) .gallery__caption { color: rgba(255,255,255,0.65); }
  :global(.section--dark) .gallery__counter { color: rgba(255,255,255,0.5); }

  /* thumbs */
  .gallery__thumbs {
    display: flex;
    gap: 0.5rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding-bottom: 0.25rem;
    scrollbar-width: thin;
  }
  .gallery__thumb {
    flex: 0 0 clamp(96px, 11vw, 132px);
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-sm);
    overflow: hidden;
    scroll-snap-align: start;
    border: 1px solid transparent;
    transition: border-color var(--dur-fast) var(--ease-out),
                opacity var(--dur-fast) var(--ease-out);
    opacity: 0.55;
  }
  .gallery__thumb img { width: 100%; height: 100%; object-fit: cover; }
  .gallery__thumb[data-active='true'] {
    border-color: var(--accent);
    opacity: 1;
  }
  .gallery__thumb:hover { opacity: 1; }
</style>

<script>
  const gallery = document.querySelector<HTMLElement>('[data-gallery]');
  if (gallery) {
    const slides = Array.from(gallery.querySelectorAll<HTMLElement>('.gallery__main'));
    const thumbs = Array.from(gallery.querySelectorAll<HTMLButtonElement>('.gallery__thumb'));
    const caption = gallery.querySelector<HTMLElement>('[data-gal-caption]');
    const counter = gallery.querySelector<HTMLElement>('[data-gal-current]');
    let idx = 0;

    function go(next: number) {
      slides[idx].dataset.active = 'false';
      thumbs[idx].dataset.active = 'false';
      idx = (next + slides.length) % slides.length;
      slides[idx].dataset.active = 'true';
      thumbs[idx].dataset.active = 'true';
      const alt = slides[idx].querySelector('img')?.alt ?? '';
      if (caption) caption.textContent = alt;
      if (counter) counter.textContent = String(idx + 1).padStart(2, '0');
      thumbs[idx].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
    }
    gallery.querySelector('[data-gal-prev]')?.addEventListener('click', () => go(idx - 1));
    gallery.querySelector('[data-gal-next]')?.addEventListener('click', () => go(idx + 1));
    thumbs.forEach((t) => t.addEventListener('click', () => go(Number(t.dataset.go))));
    gallery.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft')  go(idx - 1);
      if (e.key === 'ArrowRight') go(idx + 1);
    });
  }
</script>
